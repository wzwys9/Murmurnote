<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Murmurnote" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Compose 首帧渲染前那一帧由系统绘制 windowBackground;沿用 Light Material 的默认白会造成
             冷启动→录音页之间一闪白屏。改成 Compose 主题里同一个 BgWarm,首帧就一致,无可见过渡。 -->
        <item name="android:windowBackground">@color/bg_warm</item>
        <item name="android:colorBackground">@color/bg_warm</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
